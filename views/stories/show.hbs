{{! Individual Story board }}
<div class="story-show-wrapper">

  {{! ── METADATA BANNER ── }}
  <div class="story-banner">
    <div class="story-banner-inner">
      <p class="story-breadcrumb">
        <a href="/stories">Stories</a>
        <i class="fas fa-chevron-right fa-xs"></i>
        Fiction
      </p>
      <div class="story-meta-block">
        <div class="story-meta-text">
          <h4 class="story-title">
            {{story.title}}
            {{{editIcon story.user user story._id false}}}
          </h4>
          <p class="story-author-line">
            By: <a href="/stories/user/{{story.user._id}}">{{story.user.displayName}}</a>
          </p>
          {{#if story.description}}
            <p class="story-description">{{story.description}}</p>
          {{/if}}
          <p class="story-meta-inline">
            <span>Chapters: <strong>{{totalChapters}}</strong></span>
            <span class="meta-divider">·</span>
            <span>Status: <strong>{{story.status}}</strong></span>
            <span class="meta-divider">·</span>
            <span>Published: <strong>{{formatDate story.createdAt "MMM Do YYYY"}}</strong></span>
          </p>
        </div>
      </div>
    </div>
  </div>

  {{! ── CHAPTER NAV BAR ── }}
  <div class="chapter-nav-bar">
    <div class="chapter-nav-inner">

      {{! Left: Reader formatters }}
      <div class="reader-controls">
        <button class="reader-btn" id="font-decrease" title="Decrease font size">A-</button>
        <button class="reader-btn" id="font-reset" title="Reset font size">A</button>
        <button class="reader-btn" id="font-increase" title="Increase font size">A+</button>
        <div class="reader-divider"></div>
        <button class="reader-btn" id="spacing-toggle" title="Toggle line spacing">
          <i class="fas fa-bars"></i>
        </button>
        <button class="reader-btn" id="font-toggle" title="Cycle through 5 reader fonts">Tl</button>
        <button class="reader-btn" id="theme-toggle" title="Toggle dark mode">&#9684;</button>
        <button class="reader-btn" id="tts-toggle" title="Text-to-speech" style="display: none;">
          <i class="fas fa-microphone"></i>
        </button>
      </div>

      {{! Right: Chapter selector + pagination }}
      <div class="chapter-jump-btns">
        {{#if prevChapter}}
          <a href="/stories/{{story._id}}?chapter={{prevChapter}}" class="jump-btn">
            <i class="fas fa-chevron-left"></i>
            <span class="btn-text">Prev</span>
          </a>
        {{else}}
          <span class="jump-btn disabled">
            <i class="fas fa-chevron-left"></i>
            <span class="btn-text">Prev</span>
          </span>
        {{/if}}

        <span class="pag-count">{{currentChapter}} / {{totalChapters}}</span>

        {{! Chapter dropdown selector (only if >1 chapters) }}
        {{#if (gt totalChapters 1)}}
          <div class="chapter-dropdown-wrapper">
            <button class="chapter-dropdown-btn" id="chapterDropdownBtn" title="Select chapter">
              <i class="fas fa-list"></i>
              <span class="dropdown-text">Chapters</span>
              <i class="fas fa-chevron-down dropdown-arrow"></i>
            </button>
            <div class="chapter-dropdown-menu" id="chapterDropdownMenu">
              {{#each story.chapters}}
                <a href="/stories/{{../story._id}}?chapter={{this.chapterNumber}}" 
                   class="chapter-dropdown-item {{#if (eq this.chapterNumber ../currentChapter)}}active{{/if}}"
                   data-chapter="{{this.chapterNumber}}">
                  {{!-- <span class="chapter-num">{{this.chapterNumber}}</span> --}}
                  <span class="chapter-title-text">{{this.title}}</span>
                  {{#if (eq this.chapterNumber ../currentChapter)}}
                    <i class="fas fa-check chapter-check"></i>
                  {{/if}}
                </a>
              {{/each}}
            </div>
          </div>
        {{/if}}

        {{#if nextChapter}}
          <a href="/stories/{{story._id}}?chapter={{nextChapter}}" class="jump-btn">
            <span class="btn-text">Next</span>
            <i class="fas fa-chevron-right"></i>
          </a>
        {{else}}
          <span class="jump-btn disabled">
            <span class="btn-text">Next</span>
            <i class="fas fa-chevron-right"></i>
          </span>
        {{/if}}
      </div>

    </div>
  </div>

  {{! ── CHAPTER DROPDOWN SCRIPT ── }}
  <script>
    (function () {
      const dropdownBtn = document.getElementById('chapterDropdownBtn');
      const dropdownMenu = document.getElementById('chapterDropdownMenu');
      
      if (dropdownBtn && dropdownMenu) {
        dropdownBtn.addEventListener('click', function (e) {
          e.stopPropagation();
          dropdownMenu.classList.toggle('show');
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function (e) {
          if (!dropdownMenu.contains(e.target) && e.target !== dropdownBtn) {
            dropdownMenu.classList.remove('show');
          }
        });

        // Prevent dropdown from closing when clicking inside
        dropdownMenu.addEventListener('click', function (e) {
          e.stopPropagation();
        });
      }
    })();
  </script>

  {{! ── READER PREFS SCRIPT (FIXED + 5 FONTS) ── }}
  <script>
    (function () {
      const body = document.body;
      const STORAGE_KEY = 'fp_reader_prefs';
      const defaults = {
        fontSize: 1.08,
        spacing: 1.95,
        fontFamily: 'georgia',
        darkMode: false
      };

      // 5 Reader-Optimized Font Stacks
      const fontStacks = [
        { key: 'georgia',      css: "'Georgia', 'Times New Roman', serif" },
        { key: 'charter',      css: "'Charter', 'Bitstream Charter', 'Sitka Text', 'Cambria', serif" },
        { key: 'iowan',        css: "'Iowan Old Style', 'Palatino Linotype', 'URW Palladio L', 'P052', serif" },
        { key: 'seravek',      css: "'Seravek', 'Gill Sans Nova', 'Ubuntu', 'Calibri', 'DejaVu Sans', sans-serif" },
        { key: 'literata',     css: "'Literata', 'Iowan Old Style', 'Apple Garamond', 'Baskerville', 'Times New Roman', serif" }
      ];

      function loadPrefs() {
        try {
          return Object.assign({}, defaults, JSON.parse(localStorage.getItem(STORAGE_KEY)));
        } catch (e) {
          return Object.assign({}, defaults);
        }
      }

      function savePrefs(prefs) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(prefs));
      }

      function applyPrefs(prefs) {
        const chapterBody = document.querySelector('.chapter-body');
        if (chapterBody) {
          chapterBody.style.fontSize = prefs.fontSize + 'rem';
          chapterBody.style.lineHeight = prefs.spacing;
          const currentFont = fontStacks.find(f => f.key === prefs.fontFamily) || fontStacks[0];
          chapterBody.style.fontFamily = currentFont.css;
        }

        const targets = [
          document.querySelector('.story-show-wrapper'),
          document.querySelector('.story-banner'),
          document.querySelector('.chapter-content-wrapper'),
          document.querySelector('.chapter-pagination')
        ];

        if (prefs.darkMode) {
          body.classList.add('reader-dark');
          targets.forEach(el => { if (el) el.classList.add('reader-dark'); });
          const btn = document.getElementById('theme-toggle');
          if (btn) btn.style.color = '#80cbc4';
        } else {
          body.classList.remove('reader-dark');
          targets.forEach(el => { if (el) el.classList.remove('reader-dark'); });
          const btn = document.getElementById('theme-toggle');
          if (btn) btn.style.color = '';
        }
      }

      let prefs = loadPrefs();
      applyPrefs(prefs);

      document.getElementById('font-increase').addEventListener('click', function () {
        prefs.fontSize = Math.min(parseFloat((prefs.fontSize + 0.1).toFixed(2)), 1.6);
        applyPrefs(prefs);
        savePrefs(prefs);
      });

      document.getElementById('font-decrease').addEventListener('click', function () {
        prefs.fontSize = Math.max(parseFloat((prefs.fontSize - 0.1).toFixed(2)), 0.8);
        applyPrefs(prefs);
        savePrefs(prefs);
      });

      document.getElementById('font-reset').addEventListener('click', function () {
        prefs.fontSize = defaults.fontSize;
        prefs.spacing = defaults.spacing;
        prefs.fontFamily = defaults.fontFamily;
        applyPrefs(prefs);
        savePrefs(prefs);
      });

      const spacingSteps = [1.95, 2.4, 1.5];
      document.getElementById('spacing-toggle').addEventListener('click', function () {
        const currentIndex = spacingSteps.indexOf(prefs.spacing);
        prefs.spacing = spacingSteps[(currentIndex + 1) % spacingSteps.length];
        applyPrefs(prefs);
        savePrefs(prefs);
      });

      document.getElementById('font-toggle').addEventListener('click', function () {
        const currentIndex = fontStacks.findIndex(f => f.key === prefs.fontFamily);
        const nextIndex = (currentIndex + 1) % fontStacks.length;
        prefs.fontFamily = fontStacks[nextIndex].key;
        applyPrefs(prefs);
        savePrefs(prefs);
      });

      document.getElementById('theme-toggle').addEventListener('click', function () {
        prefs.darkMode = !prefs.darkMode;
        applyPrefs(prefs);
        savePrefs(prefs);
      });
    })();
  </script>

  {{! ── TEXT-TO-SPEECH FEATURE ── }}
  <script>
    // ── TTS Manager Class ──
    class TTSManager {
      constructor(options = {}) {
        this.synth = window.speechSynthesis;
        this.utterance = null;
        this.isSupported = 'speechSynthesis' in window;
        this.isPlaying = false;
        this.isPaused = false;
        this.currentText = '';
        
        this.config = {
          rate: options.rate || 1.0,
          pitch: options.pitch || 1.0,
          volume: options.volume || 1.0,
          lang: options.lang || 'en-US',
          voice: options.voice || null
        };

        this.onStart = options.onStart || null;
        this.onEnd = options.onEnd || null;
        this.onPause = options.onPause || null;
        this.onResume = options.onResume || null;
        this.onError = options.onError || null;
      }

      checkSupport() {
        return this.isSupported;
      }

      extractTextFromHTML(htmlContent) {
        if (!htmlContent) return '';
        const temp = document.createElement('div');
        temp.innerHTML = htmlContent;
        const scripts = temp.querySelectorAll('script, style');
        scripts.forEach(el => el.remove());
        let text = temp.textContent || temp.innerText || '';
        text = text.replace(/\s+/g, ' ').replace(/\n\s*\n/g, '\n\n').trim();
        return text;
      }

      speak(text) {
        if (!this.isSupported) {
          console.warn('Speech synthesis not supported in this browser');
          if (this.onError) this.onError('not_supported');
          return false;
        }

        this.stop();
        const plainText = this.extractTextFromHTML(text);
        
        if (!plainText) {
          console.warn('No text content to speak');
          return false;
        }

        this.currentText = plainText;
        this.utterance = new SpeechSynthesisUtterance(plainText);
        
        this.utterance.rate = this.config.rate;
        this.utterance.pitch = this.config.pitch;
        this.utterance.volume = this.config.volume;
        this.utterance.lang = this.config.lang;

        if (this.config.voice) {
          this.utterance.voice = this.config.voice;
        }

        this.utterance.onstart = () => {
          this.isPlaying = true;
          this.isPaused = false;
          if (this.onStart) this.onStart();
        };

        this.utterance.onend = () => {
          this.isPlaying = false;
          this.isPaused = false;
          if (this.onEnd) this.onEnd();
        };

        this.utterance.onerror = (event) => {
          console.error('Speech synthesis error:', event);
          this.isPlaying = false;
          this.isPaused = false;
          if (this.onError) this.onError(event);
        };

        this.utterance.onpause = () => {
          this.isPaused = true;
          if (this.onPause) this.onPause();
        };

        this.utterance.onresume = () => {
          this.isPaused = false;
          if (this.onResume) this.onResume();
        };

        this.synth.speak(this.utterance);
        return true;
      }

      pause() {
        if (this.isSupported && this.isPlaying && !this.isPaused) {
          this.synth.pause();
          return true;
        }
        return false;
      }

      resume() {
        if (this.isSupported && this.isPlaying && this.isPaused) {
          this.synth.resume();
          return true;
        }
        return false;
      }

      stop() {
        if (this.isSupported) {
          this.synth.cancel();
          this.isPlaying = false;
          this.isPaused = false;
          return true;
        }
        return false;
      }

      getState() {
        return {
          isSupported: this.isSupported,
          isPlaying: this.isPlaying,
          isPaused: this.isPaused,
          isSpeaking: this.synth.speaking,
          isPending: this.synth.pending
        };
      }
    }

    // ── TTS Feature Initialization ──
    (function () {
      // Check if TTS is supported
      const ttsSupported = 'speechSynthesis' in window;
      const ttsBtn = document.getElementById('tts-toggle');
      
      if (!ttsSupported || !ttsBtn) {
        return; // Exit if not supported or button not found
      }

      // Show the TTS button since it's supported
      ttsBtn.style.display = '';

      // Initialize TTS Manager
      let ttsManager = null;
      let ttsState = 'idle'; // idle, playing, paused

      function initTTSManager() {
        const chapterBody = document.querySelector('.chapter-body');
        if (!chapterBody) {
          console.warn('Chapter body not found');
          return null;
        }

        const chapterContent = chapterBody.innerHTML;

        return new TTSManager({
          rate: 1.25,
          pitch: 1.0,
          volume: 1.0,
          lang: 'en-US',
          onStart: function() {
            ttsState = 'playing';
            updateTTSButton();
          },
          onEnd: function() {
            ttsState = 'idle';
            updateTTSButton();
          },
          onPause: function() {
            ttsState = 'paused';
            updateTTSButton();
          },
          onResume: function() {
            ttsState = 'playing';
            updateTTSButton();
          },
          onError: function(error) {
            console.error('TTS Error:', error);
            ttsState = 'idle';
            updateTTSButton();
            if (error === 'not_supported') {
              alert('Text-to-speech is not supported in your browser.');
            }
          }
        });
      }

      function updateTTSButton() {
        const icon = ttsBtn.querySelector('i');
        
        switch(ttsState) {
          case 'playing':
            icon.className = 'fas fa-pause';
            ttsBtn.style.color = '#4CAF50'; // Green when playing
            ttsBtn.title = 'Pause reading';
            break;
          case 'paused':
            icon.className = 'fas fa-play';
            ttsBtn.style.color = '#FF9800'; // Orange when paused
            ttsBtn.title = 'Resume reading';
            break;
          case 'idle':
          default:
            icon.className = 'fas fa-microphone';
            ttsBtn.style.color = '';
            ttsBtn.title = 'Text-to-speech';
            break;
        }
      }

      // TTS Button Click Handler
      ttsBtn.addEventListener('click', function(e) {
        e.preventDefault();

        // Initialize manager on first use
        if (!ttsManager) {
          ttsManager = initTTSManager();
          if (!ttsManager) return;
        }

        const chapterBody = document.querySelector('.chapter-body');
        if (!chapterBody) return;

        switch(ttsState) {
          case 'idle':
            // Start reading
            const success = ttsManager.speak(chapterBody.innerHTML);
            if (success) {
              ttsState = 'playing';
              updateTTSButton();
            }
            break;
          
          case 'playing':
            // Pause reading
            ttsManager.pause();
            ttsState = 'paused';
            updateTTSButton();
            break;
          
          case 'paused':
            // Resume reading
            ttsManager.resume();
            ttsState = 'playing';
            updateTTSButton();
            break;
        }
      });

      // Stop TTS when navigating away (prev/next chapter)
      const navLinks = document.querySelectorAll('.jump-btn, .pag-btn, .chapter-dropdown-item');
      navLinks.forEach(link => {
        link.addEventListener('click', function() {
          if (ttsManager && ttsState !== 'idle') {
            ttsManager.stop();
            ttsState = 'idle';
            updateTTSButton();
          }
        });
      });

      // Stop TTS when page is about to unload
      window.addEventListener('beforeunload', function() {
        if (ttsManager && ttsState !== 'idle') {
          ttsManager.stop();
        }
      });

      // Handle page visibility change (pause when tab is hidden)
      document.addEventListener('visibilitychange', function() {
        if (document.hidden && ttsManager && ttsState === 'playing') {
          ttsManager.pause();
          ttsState = 'paused';
          updateTTSButton();
        }
      });

    })();
  </script>

  {{! ── CHAPTER CONTENT ── }}
  <div class="chapter-content-wrapper container">
    <h5 class="chapter-heading center-align">{{chapter.title}}</h5>
    <div class="chapter-body">
      {{{chapter.content}}}
    </div>
  </div>

  {{! ── BOTTOM PAGINATION ── }}
  <div class="chapter-pagination center-align">
    {{#if prevChapter}}
      <a href="/stories/{{story._id}}?chapter={{prevChapter}}" class="pag-btn">
        <i class="fas fa-chevron-left"></i>
        <span class="btn-text">Prev</span>
      </a>
    {{else}}
      <span class="pag-btn disabled">
        <i class="fas fa-chevron-left"></i>
        <span class="btn-text">Prev</span>
      </span>
    {{/if}}
    <span class="pag-count">{{currentChapter}} / {{totalChapters}}</span>
    {{#if nextChapter}}
      <a href="/stories/{{story._id}}?chapter={{nextChapter}}" class="pag-btn">
        <span class="btn-text">Next</span>
        <i class="fas fa-chevron-right"></i>
      </a>
    {{else}}
      <span class="pag-btn disabled">
        <span class="btn-text">Next</span>
        <i class="fas fa-chevron-right"></i>
      </span>
    {{/if}}
  </div>

</div>